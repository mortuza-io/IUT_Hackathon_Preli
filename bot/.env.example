# Discord bot token (from https://discord.com/developers/applications)
# Enable the MESSAGE CONTENT intent for the bot in the developer portal.
DISCORD_TOKEN=

# Channel ID where proactive alert messages are posted (optional)
ALERT_CHANNEL_ID=1522697902458277968

# Backend the bot reads live data from
BACKEND_URL=http://localhost:3000

# Optional: enables LLM-generated conversational replies.
# Without it the bot falls back to friendly built-in templates.
OPENAI_API_KEY=
